    function actualizarFechaHoy() {
      const hoy = new Date();
      try {
        const opciones = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        let fechaFormateada = hoy.toLocaleDateString('es-PE', opciones);
        const fechaCapitalizada = fechaFormateada.charAt(0).toUpperCase() + fechaFormateada.slice(1);
        const el = document.getElementById('fechaHoy');
        if (el) el.textContent = fechaCapitalizada;
      } catch (e) {
        const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
        const dias = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];
        const f = `${dias[hoy.getDay()]}, ${hoy.getDate()} de ${meses[hoy.getMonth()]} de ${hoy.getFullYear()}`;
        const el = document.getElementById('fechaHoy');
        if (el) el.textContent = f.charAt(0).toUpperCase() + f.slice(1);
      }
      setTimeout(actualizarFechaHoy, 60000);
    }

