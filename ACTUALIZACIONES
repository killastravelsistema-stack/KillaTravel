    // ═══════════════════════════════════════════
    //  FORMULARIO - PASAJEROS
    // ═══════════════════════════════════════════
    function agregarFilaPax() {
      const div = document.createElement('div');
      div.className = 'pax-row';
      div.innerHTML = `
        <div class="campo">
          <label>Nombre</label>
