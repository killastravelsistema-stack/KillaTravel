    async function cargarDatos() {
      document.getElementById('lista-datos').innerHTML =
        '<tr><td colspan="20" style="padding:40px;text-align:center;color:var(--texto-gris);">Cargando...</td></tr>';
      try {
        var { data, error } = await _supa
          .from('ventas')
          .select('*')
          .order('correlativo', { ascending: true })
          .order('id', { ascending: true });
        if (error) throw error;
        window._datosRowsCache = data || [];
        renderDatos(window._datosRowsCache);
      } catch(err) {
        document.getElementById('lista-datos').innerHTML =
          '<tr><td colspan="20" style="padding:40px;text-align:center;color:#ef4444;">❌ Error: ' + (err.message||'') + '</td></tr>';
      }
    }

    function renderDatos(rows) {
      if (!rows || rows.length === 0) {
        document.getElementById('lista-datos').innerHTML =
          '<tr><td colspan="20" style="padding:40px;text-align:center;color:var(--texto-gris);">No hay registros</td></tr>';
        return;
      }

      // Ordenar por fecha cronológicamente (más antiguo primero) para agrupar bien los meses (Antiguos a más recientes)
      var sortedRows = rows.slice().sort(function(a, b) {
        var d1 = _parseFecha(a.fecha) || new Date(0);
        var d2 = _parseFecha(b.fecha) || new Date(0);
        if (d1.getTime() === d2.getTime()) return (a.correlativo||0) - (b.correlativo||0); // Stable sort fallback
        return d1 - d2;
      });

      // Banner de bloqueo para montos admin
      var bannerDatos = document.getElementById('banner-datos-lock');
      if (bannerDatos) bannerDatos.style.display = _adminDesbloqueado ? 'none' : 'flex';

      var OCULTO = '<span style="filter:blur(4px);user-select:none;letter-spacing:2px;">●●●●●</span>';
      var td = function(val, align) {
        return '<td style="padding:10px;border-bottom:1px solid var(--borde);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:0;text-align:' + (align||'left') + ';" title="' + String(val||'').replace(/<[^>]*>/g,'') + '">' + (val||'—') + '</td>';
      };
      var tdTextWrap = function(val) {
        return '<td style="padding:10px;border-bottom:1px solid var(--borde);font-size:12px;white-space:normal;word-break:break-word;min-width:150px;text-align:left;">' + (val||'—') + '</td>';
      };
      var tdFecha = function(val, color) {
        return '<td style="padding:10px;border-bottom:1px solid var(--borde);font-size:12px;white-space:nowrap;' + color + '">' + (val||'—') + '</td>';
      };
      // Contar repeticiones de la misma reserva (numero_doc)
      var countMap = {};
      sortedRows.forEach(function(r) {
        var nd = r.numero_doc || 'SIN_DOC';
        countMap[nd] = (countMap[nd] || 0) + 1;
      });
      // Agrupación por mes
      var MESES_ES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
      var ultimoMes = null;
      var html = sortedRows.map(function(r) {
        var fechaDoc = _parseFecha(r.fecha);
        var mesActual = fechaDoc ? fechaDoc.getMonth() : -1;
        var anioActual = fechaDoc ? fechaDoc.getFullYear() : 0;
        var grupoMes = '';
        if (ultimoMes === null || ultimoMes.mes !== mesActual || ultimoMes.anio !== anioActual) {
          grupoMes = '<tr style="background:#f0f9ff;"><td colspan="20" style="padding:8px 10px;font-weight:bold;font-size:13px;color:#0369a1;border-bottom:1px solid var(--borde);">' + MESES_ES[mesActual] + ' ' + anioActual + '</td></tr>';
          ultimoMes = { mes: mesActual, anio: anioActual };
        }

        var hoy = new Date();
        var calcColor = function(dateStr) {
          if (!dateStr || dateStr === '---' || String(dateStr).trim() === '') return '';
          var f = _parseFecha(dateStr);
          if (!f) return '';
          f.setHours(0,0,0,0);
          var diff = Math.floor((f - hoy) / 86400000);
          if (diff < 0)  return 'color:#10b981;font-weight:800;';
          if (diff <= 2) return 'color:#ef4444;font-weight:800;background:#fee2e2;border-radius:4px;padding:0 4px;';
          return '';
        };
        // Helper inline para formatear fecha ISO → DD/MM/YYYY
        var fmtFecha = function(s) {
          if (!s || s === '---') return '—';
          s = String(s).trim();
          if (/^\d{4}-\d{2}-\d{2}$/.test(s)) { var p=s.split('-'); return p[2]+'/'+p[1]+'/'+p[0]; }
          return s;
        };
        var nac = fmtFecha(r.fecha_nacimiento);
        var fsal = fmtFecha(r.fecha_salida);
        var fret = fmtFecha(r.fecha_retorno);

        var nd = r.numero_doc || 'SIN_DOC';
        var splitBy = countMap[nd] || 1;
        var rComision = (parseFloat(r.comision) || 0) / splitBy;
        var rNeto = (parseFloat(r.neto) || 0) / splitBy;
        var rTotal = (parseFloat(r.total) || 0) / splitBy;

        var comVal = _adminDesbloqueado ? ('$ ' + rComision.toFixed(2)) : OCULTO;
        var netVal = _adminDesbloqueado ? ('$ ' + rNeto.toFixed(2))     : OCULTO;
        var totVal = _adminDesbloqueado ? ('<b>$ ' + rTotal.toFixed(2) + '</b>') : OCULTO;

        var colorSal = calcColor(r.fecha_salida);
        var colorRet = calcColor(r.fecha_retorno);
        var diffDiasRegistro = fechaDoc ? Math.floor((new Date() - fechaDoc) / 86400000) : 999;
        var badgeNuevo = (diffDiasRegistro >= 0 && diffDiasRegistro <= 7) ? '<span style="display:inline-block;margin-left:6px;background:#10b981;color:white;padding:2px 6px;border-radius:4px;font-size:9px;font-weight:800;vertical-align:middle;">NUEVO</span>' : '';

        return grupoMes + '<tr>' +
          td('<b>' + (r.numero_doc||'') + '</b>' + badgeNuevo) +
          td(r.fecha||'') +
          tdTextWrap(r.titular||'') +
          tdTextWrap(r.pasajero||'') +
          tdFecha(fsal, colorSal) +
          tdFecha(fret, colorRet) +
          td(r.ruta||'') +
          td(r.dni_ruc||'') +
          td(r.aerolinea||'') +
          td(r.codigo_reserva||'') +
          td(r.celular||'') +
          td('<span style="font-size:10px;">' + (r.direccion||'').substring(0,30) + (r.direccion&&r.direccion.length>30?'...':'') + '</span>') +
          td(r.tipo_emision||'') +
          td(r.counter||'') +
          td(r.metodo_pago||'') +
          td(nac||'') +
          td(comVal, 'right') +
          td(netVal, 'right') +
          td(totVal, 'right') +
          td('$ ' + parseFloat(r.importe_individual||0).toFixed(2), 'right') +
          '<td style="padding:8px;border-bottom:1px solid var(--borde);text-align:center;">' +
          '<button onclick="abrirEditar(' + r.id + ')" style="background:linear-gradient(135deg,#10b981,#059669);color:white;border:none;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:700;white-space:nowrap;margin-bottom:5px;">Editar</button>' +
          '<br><label style="font-size:10px; cursor:pointer; color:#0369a1; font-weight:700; display:flex; align-items:center; justify-content:center; gap:4px;"><input type="checkbox" onclick="toggleVerificado(' + r.id + ', this.checked)" ' + (String(r.observacion||'').includes('[✓ REVISADO]') ? 'checked' : '') + '> OK</label>' +
          '</td>' +
          '<td id="obs_text_' + r.id + '" style="padding:10px;border-bottom:1px solid var(--borde);font-size:12px;min-width:120px;white-space:normal;word-break:break-word;">' +
          '<span style="color:#0369a1;">' + (r.observacion || '<span style="color:#94a3b8;font-style:italic;">—</span>') + '</span>' +
          '</td>' +
          '</tr>';
      }).join('');
      document.getElementById('lista-datos').innerHTML = html;
    }


    // ═══════════════════════════════════════════
    //  EDITAR REGISTRO → SUPABASE
    // ═══════════════════════════════════════════
    function abrirEditar(rowId) {
      var pin = prompt('⚠️ Ingresa el PIN para editar:');
      if (pin !== '1997') {
        if (pin !== null) alert('❌ PIN Incorrecto');
        return;
      }

      var rows = window._datosRowsCache || [];
      var r = rows.find(function(x){ return x.id === rowId; });
      if (!r) { alert('❌ Registro no encontrado en caché. Refresca la tabla primero.'); return; }

      // Función para convertir fechas DD/MM/YYYY o cualquier formato a YYYY-MM-DD para el input type=date
      function toInputDate(s) {
        if (!s || s === '---') return '';
        s = String(s).trim();
        if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s; // ya está en ISO
        var m = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
        if (m) return m[3] + '-' + m[2].padStart(2,'0') + '-' + m[1].padStart(2,'0');
        return '';
      }

      document.getElementById('edit_id').value         = r.id;
      document.getElementById('edit_titular').value    = r.titular || '';
      document.getElementById('edit_fecha_doc').value  = r.fecha || '';
      document.getElementById('edit_dni').value        = r.dni_ruc || '';
      document.getElementById('edit_pasajero').value   = r.pasajero || '';
      document.getElementById('edit_celular').value    = r.celular || '';
      document.getElementById('edit_ruta').value       = r.ruta || '';
      document.getElementById('edit_aerolinea').value  = r.aerolinea || '';
      document.getElementById('edit_reserva').value    = r.codigo_reserva || '';
      document.getElementById('edit_metodo').value     = r.metodo_pago || '';
      document.getElementById('edit_salida').value     = toInputDate(r.fecha_salida);
      document.getElementById('edit_retorno').value    = toInputDate(r.fecha_retorno);
      document.getElementById('edit_nacimiento').value = toInputDate(r.fecha_nacimiento);
      document.getElementById('edit_comision').value   = r.comision || '';
      document.getElementById('edit_neto').value       = r.neto || '';
      document.getElementById('edit_total').value      = r.total || '';
      document.getElementById('edit_importe').value    = r.importe_individual || '';
      document.getElementById('edit_counter').value    = r.counter || '';
      document.getElementById('edit_observacion').value = r.observacion || '';

      document.getElementById('modalEditar').style.display = 'flex';
    }

    function cerrarEditar() {
      document.getElementById('modalEditar').style.display = 'none';
    }

    async function guardarEdicion() {
      var btn = document.getElementById('btnGuardarEdicion');
      var rowId = parseInt(document.getElementById('edit_id').value);
      if (!rowId) { alert('❌ Error: ID de registro no encontrado.'); return; }

      btn.innerHTML = '⏳ Guardando...';
      btn.disabled = true;

      var updates = {
        titular:          document.getElementById('edit_titular').value.toUpperCase(),
        dni_ruc:          document.getElementById('edit_dni').value,
        pasajero:         document.getElementById('edit_pasajero').value.toUpperCase(),
        celular:          document.getElementById('edit_celular').value,
        ruta:             document.getElementById('edit_ruta').value.toUpperCase(),
        aerolinea:        document.getElementById('edit_aerolinea').value.toUpperCase(),
        codigo_reserva:   document.getElementById('edit_reserva').value.toUpperCase(),
        metodo_pago:      document.getElementById('edit_metodo').value,
        fecha_salida:     document.getElementById('edit_salida').value || null,
        fecha_retorno:    document.getElementById('edit_retorno').value || null,
        fecha_nacimiento: document.getElementById('edit_nacimiento').value || null,
        comision:         parseFloat(document.getElementById('edit_comision').value) || 0,
        neto:             parseFloat(document.getElementById('edit_neto').value) || 0,
        total:            parseFloat(document.getElementById('edit_total').value) || 0,
        importe_individual: parseFloat(document.getElementById('edit_importe').value) || 0,
        counter:          document.getElementById('edit_counter').value,
        fecha:            document.getElementById('edit_fecha_doc').value || undefined,
        observacion:      document.getElementById('edit_observacion').value || ''
      };

      try {
        var { error } = await _supa.from('ventas').update(updates).eq('id', rowId);
        if (error) throw error;

        // Actualizar caché local
        var rows = window._datosRowsCache || [];
        var idx = rows.findIndex(function(x){ return x.id === rowId; });
        if (idx !== -1) Object.assign(rows[idx], updates);

        // Actualizar checkin toggle
        var checkinActivo = document.getElementById('edit_checkin_activo').checked;
        var fS = updates.fecha_salida || '';
        var fR = updates.fecha_retorno || '';
        var kS = (updates.titular||'') + '|SALIDA|' + fS;
        var kR = (updates.titular||'') + '|RETORNO|' + fR;
        var descList = JSON.parse(localStorage.getItem('killa_alertas_desc') || '[]');

        if (checkinActivo) {
          // Activar = QUITAR de descartados
          descList = descList.filter(function(k) { return k !== kS && k !== kR; });
        } else {
          // Desactivar = AGREGAR a descartados
          if (fS && !descList.includes(kS)) descList.push(kS);
          if (fR && fR !== '---' && !descList.includes(kR)) descList.push(kR);
        }
        localStorage.setItem('killa_alertas_desc', JSON.stringify(descList));
        window._alertasDescartadas = descList; // Actualizar variable global en JS

        cerrarEditar();
        alert('✅ Registro actualizado correctamente');
        cargarAlertas(); // Recarga sección check-in
        cargarDatos();   // Refresca la tabla desde la DB
      } catch(err) {
        alert('❌ Error al guardar: ' + (err.message || String(err)));
      } finally {
        btn.innerHTML = '💾 Guardar Cambios';
        btn.disabled = false;
      }
    }

    function exportarCSV() {
      _supa.from('ventas').select('*').order('correlativo',{ascending:false}).order('id',{ascending:true})
        .then(function(res) {
          var rows = res.data || [];
          if (!rows.length) { alert('No hay datos para exportar'); return; }
          var headers = ['# Doc','Fecha','Comprador','DNI/RUC','Pasajero','Cod.Reserva','Aerolinea','Ruta','F.Salida','F.Retorno','Celular','Direccion','Tipo','Counter','Metodo Pago','F.Nacimiento','Comision','Neto','Cobrado','Importe Ind.'];
          var csv = headers.join(',') + '\n';
          rows.forEach(function(r) {
            var nac = String(r.fecha_nacimiento||'').trim();
            if (/^\d{4}-\d{2}-\d{2}$/.test(nac)) { var p=nac.split('-'); nac=p[2]+'/'+p[1]+'/'+p[0]; }
            var fsal = String(r.fecha_salida||'').trim();
            if (/^\d{4}-\d{2}-\d{2}$/.test(fsal)) { var p=fsal.split('-'); fsal=p[2]+'/'+p[1]+'/'+p[0]; }
            var col = function(v) { return '"' + String(v||'').replace(/"/g,'""') + '"'; };
            csv += [col(r.numero_doc),col(r.fecha),col(r.titular),col(r.dni_ruc),col(r.pasajero),col(r.codigo_reserva),col(r.aerolinea),col(r.ruta),col(fsal),col(r.fecha_retorno),col(r.celular),col(r.direccion),col(r.tipo_emision),col(r.counter),col(r.metodo_pago),col(nac),r.comision,r.neto,r.total,r.importe_individual].join(',') + '\n';
          });
          var blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
          var url  = URL.createObjectURL(blob);
          var a    = document.createElement('a');
          a.href = url; a.download = 'KillaTravel_Datos_' + new Date().toISOString().slice(0,10) + '.csv';
          a.click(); URL.revokeObjectURL(url);
        });
    }

    // ═══════════════════════════════════════════
    //  COLOR DE FECHAS (igual que Google Sheets)
    // ═══════════════════════════════════════════
    function _getDateColor(dateStr) {
      if (!dateStr || dateStr === '---' || String(dateStr).trim() === '') return '';
      var fecha = _parseFecha(dateStr);
      if (!fecha) return '';
      var hoy = new Date(); hoy.setHours(0,0,0,0);
      fecha.setHours(0,0,0,0);
      var diff = Math.floor((fecha - hoy) / 86400000);
      if (diff < 0)  return 'color:#10b981;font-weight:700;';                                    // 🟢 verde – ya viajó
      if (diff <= 2) return 'color:#ef4444;font-weight:800;background:#fee2e2;border-radius:4px;'; // 🔴 rojo – menos de 2 días
      return ''; // normal
    }

    // ═══════════════════════════════════════════
    //  PARSEAR TSV (copiado desde Google Sheets)
    // ═══════════════════════════════════════════
    function parseTSV(text) {
      var rows = [], row = [], inQ = false, cell = '';
      for (var i = 0; i < text.length; i++) {
        var ch = text[i];
        if (ch === '"') {
          if (inQ && text[i+1] === '"') { cell += '"'; i++; } else inQ = !inQ;
        } else if (ch === '\t' && !inQ) {
          row.push(cell.trim()); cell = '';
        } else if ((ch === '\n' || ch === '\r') && !inQ) {
          if (ch === '\r' && text[i+1] === '\n') i++;
          row.push(cell.trim());
          if (row.some(function(c){return c.length>0;})) rows.push(row);
          row = []; cell = '';
        } else { cell += ch; }
      }
      if (cell || row.length > 0) { row.push(cell.trim()); if (row.some(function(c){return c.length>0;})) rows.push(row); }
      return rows;
    }

    // ═══════════════════════════════════════════
    //  ABRIR MODAL IMPORTAR
    // ═══════════════════════════════════════════
    function abrirImportar() {
      document.getElementById('modalImportar').style.display = 'grid';
      document.getElementById('import-textarea').value = '';
