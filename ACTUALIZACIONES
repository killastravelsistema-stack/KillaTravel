    function reimprimirBoleto(numeroDoc) {
      const doc = db.find(d => d.numeroDoc === numeroDoc);
      if (!doc) { alert('❌ Documento no encontrado en caché. Recarga la sección Boletos.'); return; }
      generarTicket(doc);
    }

    // ═══════════════════════════════════════════
    //  CARGAR ALERTAS (desde cache Supabase)
    // ═══════════════════════════════════════════
    async function cargarAlertas() {
      document.getElementById('lista-alertas').innerHTML =
        '<tr><td colspan="4" style="padding:40px;text-align:center;color:var(--texto-gris);">Cargando alertas...</td></tr>';
      try {
        if (db.length === 0) db = await _fetchVentas();
        var hoy = new Date(); hoy.setHours(0,0,0,0);
        var alertas = [];
        db.filter(function(v){ return !v.anulado; }).forEach(function(v) {
          var cel = v.cel || '';
          
          // SALIDA
          var fSal = _parseFecha(v.fechaSalida);
          if (fSal) { 
            var f = new Date(fSal); f.setHours(0,0,0,0);
            var ds = Math.floor((f-hoy)/86400000); 
            if (ds >= -1 && ds <= 2) {
              var paxs = (v.pasajeros||[]).map(function(p){return p.nom||'';}).join(', ');
              alertas.push({ 
                pasajero: paxs || v.titular, titular: v.titular, ruta: v.ruta, 
                salida: v.fechaSalida, tipo: 'SALIDA', cel: cel, diasFaltan: ds, key: (v.titular||'')+'|SALIDA|'+(v.fechaSalida||'')
              }); 
            }
          }
          
          // RETORNO
          var fRet = _parseFecha(v.fechaRetorno);
          if (fRet && v.fechaRetorno && v.fechaRetorno !== '---') { 
            var f2 = new Date(fRet); f2.setHours(0,0,0,0);
            var dr = Math.floor((f2-hoy)/86400000); 
            if (dr >= -1 && dr <= 2) {
              var paxs2 = (v.pasajeros||[]).map(function(p){return p.nom||'';}).join(', ');
              alertas.push({ 
                pasajero: paxs2 || v.titular, titular: v.titular, ruta: v.ruta, 
                salida: v.fechaRetorno, tipo: 'RETORNO', cel: cel, diasFaltan: dr, key: (v.titular||'')+'|RETORNO|'+(v.fechaRetorno||'')
              }); 
            }
          }
        });
        // Ordenar: primero los más antiguos (negativos = verdes), luego los próximos
        alertas.sort(function(a,b){ return a.diasFaltan - b.diasFaltan; });
        
        // Guardar para la exportación global si es necesario
        window._alertasExportables = alertas;
        
        renderAlertas(alertas);
      } catch(err) {
        document.getElementById('lista-alertas').innerHTML =
          '<tr><td colspan="4" style="padding:40px;text-align:center;color:#ef4444;">❌ Error al cargar alertas</td></tr>';
      }
    }

    // Alertas descartadas manualmente (verde)
    var _alertasDescartadas = JSON.parse(localStorage.getItem('killa_alertas_desc') || '[]');
    function descartarAlerta(key) {
      if (!_alertasDescartadas.includes(key)) _alertasDescartadas.push(key);
      localStorage.setItem('killa_alertas_desc', JSON.stringify(_alertasDescartadas));
      cargarAlertas();
    }

    function renderAlertas(alertasTodas) {
      // Separar las activas de las descartadas (estas últimas no se muestran)
      var alertasActivas = alertasTodas.filter(function(a) {
        return !_alertasDescartadas.includes(a.key);
      });
