    function verBoletoCompleto(numeroDoc) {
      const doc = db.find(d => d.numeroDoc === numeroDoc);
      if (!doc) { alert('❌ Documento no encontrado'); return; }

      let detalles =
        '📋 ' + doc.numeroDoc + '\n' +
        '📅 ' + (doc.fecha||'') + '\n' +
        '🏢 ' + (doc.ofi||'') + '\n\n' +
        '👤 COMPRADOR:\n' +
        '   ' + (doc.titular||'') + '\n' +
        '   DNI: ' + (doc.doc||'') + '\n' +
        '   Tel: ' + (doc.cel||'') + '\n\n' +
        '✈️ VIAJE:\n' +
        '   Ruta: ' + (doc.ruta||'') + '\n' +
        '   Aerolínea: ' + (doc.aerolinea||'N/A') + '\n' +
        '   Código: ' + (doc.codigo_reserva||'N/A') + '\n\n' +
        '💰 PAGOS:\n' +
        '   Total: $' + (doc.total||0) + '\n' +
        '   Neto: $' + (doc.neto||0) + '\n' +
        '   Método: ' + (doc.met||'') + '\n\n' +
        '👨‍💼 Counter: ' + (doc.staff||'') + '\n\n' +
        '👥 PASAJEROS (' + (doc.pasajeros ? doc.pasajeros.length : 0) + '):\n';

      if (doc.pasajeros) {
