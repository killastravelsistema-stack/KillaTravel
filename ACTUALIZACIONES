  <script>
    // ═══════════════════════════════════════════
    //  SUPABASE CONFIG
    // ═══════════════════════════════════════════
    const SUPABASE_URL = 'https://yzuugqmomedkktmqfvak.supabase.co';
    const SUPABASE_KEY = 'sb_publishable_HEiLGIdVxXhklObErdPXdg_2Dj4aw_m';
    const _supa = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
    const PIN_CORRECTO = '1305';

    let db = [];           // Cache local de ventas
    let _guardando = false; // Flag anti-doble-submit

    // ═══════════════════════════════════════════
    //  HELPERS DE FECHA
    // ═══════════════════════════════════════════
    function _fmtDDMMYYYY(isoStr) {
      if (!isoStr || isoStr === '---' || String(isoStr).trim() === '') return '---';
      var s = String(isoStr).trim();
      if (/^\d{2}\/\d{2}\/\d{4}$/.test(s)) return s;
      if (/^\d{2}-\d{2}-\d{4}$/.test(s)) return s.replace(/-/g, '/');
      var m = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if (m) return m[3] + '/' + m[2] + '/' + m[1];
      return s;
    }

    function _parseFecha(str) {
      if (!str || str === '---') return null;
      var s = String(str).trim();
      if (/^\d{4}-\d{2}-\d{2}$/.test(s)) { var d = new Date(s + 'T00:00:00'); return isNaN(d.getTime()) ? null : d; }
      var m = s.match(/^(\d{1,2})[\/-](\d{1,2})[\/-](\d{4})$/);
      if (m) return new Date(+m[3], +m[2]-1, +m[1]);
      return null;
    }

    // ═══════════════════════════════════════════
    //  FETCH VENTAS desde Supabase
    // ═══════════════════════════════════════════
    async function _fetchVentas(query) {
      var { data, error } = await _supa
        .from('ventas')
        .select('*')
        .order('correlativo', { ascending: true })
        .order('id', { ascending: true });
      if (error) throw error;
      var mapa = {};
      (data || []).forEach(function(f) {
        var nd = f.numero_doc || ''; if (!nd) return;
        if (!mapa[nd]) {
          mapa[nd] = {
            numeroDoc: nd, fecha: f.fecha||'', titular: f.titular||'',
            doc: f.dni_ruc||'', codigo_reserva: f.codigo_reserva||'',
            aerolinea: f.aerolinea||'', ruta: f.ruta||'',
            fechaSalida: f.fecha_salida||'', fechaRetorno: f.fecha_retorno||'',
            cel: f.celular||'', ofi: f.direccion||'',
            tipo: f.tipo_emision||'', staff: f.counter||'',
            met: f.metodo_pago||'', neto: String(f.neto||'0'),
            comision: String(f.comision||'0'), total: String(f.total||'0'),
            anulado: f.anulado||false, serie: f.serie||nd.split(' - ')[0],
            correlativo: f.correlativo||0, pasajeros: []
          };
        }
        mapa[nd].pasajeros.push({
          nom: f.pasajero||'', nac: f.fecha_nacimiento||'',
          pre: String(f.importe_individual||'0'),
          sal: f.fecha_salida||'', ret: f.fecha_retorno||''
        });
      });
      var ventas = Object.values(mapa);
      if (query) {
        var q = query.toUpperCase().trim();
        // Detectar búsqueda por mes: "enero", "febrero", etc o "03/2026"
        var mesesES = {enero:1,febrero:2,marzo:3,abril:4,mayo:5,junio:6,julio:7,agosto:8,septiembre:9,octubre:10,noviembre:11,diciembre:12};
        var mesFiltro = mesesES[q.toLowerCase()];
        if (mesFiltro) {
          ventas = ventas.filter(function(v) {
            var f = _parseFecha(v.fecha);
            return f && (f.getMonth()+1) === mesFiltro;
          });
        } else {
          ventas = ventas.filter(function(v) {
            var haystack = [v.titular,v.doc,v.cel,v.ruta,v.staff,v.tipo,v.aerolinea,v.codigo_reserva,v.numeroDoc,v.fecha]
              .join(' ').toUpperCase();
            
            // Si el user busca "12 de marzo" o similar
            var fechaLarga = '';
            var fObj = _parseFecha(v.fecha);
            if(fObj) {
              var mNames = ['ENERO','FEBRERO','MARZO','ABRIL','MAYO','JUNIO','JULIO','AGOSTO','SEPTIEMBRE','OCTUBRE','NOVIEMBRE','DICIEMBRE'];
              fechaLarga = fObj.getDate() + ' DE ' + mNames[fObj.getMonth()];
            }
            haystack += ' ' + fechaLarga;

            // También buscar en nombres de pasajeros
            var paxNames = (v.pasajeros||[]).map(function(p){return p.nom||'';}).join(' ').toUpperCase();
            return haystack.indexOf(q) !== -1 || paxNames.indexOf(q) !== -1;
          });
        }
      }
      return ventas;
    }

    // ═══════════════════════════════════════════
    //  INICIALIZACIÓN
    // ═══════════════════════════════════════════
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof lucide !== 'undefined') lucide.createIcons();
