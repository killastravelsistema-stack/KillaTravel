    // ═══════════════════════════════════════════
    //  CARGAR PASAJEROS (desde cache)
    // ═══════════════════════════════════════════
    async function cargarPasajeros() {
      try {
        if (db.length === 0) db = await _fetchVentas();
        const grid = document.getElementById('pax-grid');
        var mapa = {};
        db.forEach(function(v) { var key = v.titular+'||'+v.cel; if (!mapa[key]) mapa[key] = { titular: v.titular, doc: v.cel }; });
