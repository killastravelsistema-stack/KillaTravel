    // ═══════════════════════════════════════════
    //  CARGAR BOLETOS
    // ═══════════════════════════════════════════
    async function cargarBoletos() {
      document.getElementById('lista-boletos').innerHTML =
        '<tr><td colspan="8" style="padding:40px;text-align:center;color:var(--texto-gris);">Cargando boletos...</td></tr>';
      try {
        db = await _fetchVentas();
        // SORT BOLETOS: Newest to Oldest (Recientes a más antiguos)
        db.sort(function(a, b) {
          var d1 = _parseFecha(a.fecha) || new Date(0);
          var d2 = _parseFecha(b.fecha) || new Date(0);
          if (d1.getTime() === d2.getTime()) return (b.correlativo || 0) - (a.correlativo || 0); // Stable sort fallback
          return d2 - d1;
        });
        renderBoletos();
      } catch(err) {
        document.getElementById('lista-boletos').innerHTML =
          '<tr><td colspan="8" style="padding:40px;text-align:center;color:#ef4444;">❌ Error al cargar boletos</td></tr>';
      }
    }

    function renderBoletos() {
      if (db.length === 0) {
        document.getElementById('lista-boletos').innerHTML =
          '<tr><td colspan="8" style="padding:40px;text-align:center;">No hay boletos</td></tr>';
        return;
      }

      document.getElementById('lista-boletos').innerHTML = db.map(v => {
        const esAnulado   = v.anulado;
        const estiloFila  = esAnulado ? 'opacity:0.6;background:#fef2f2;' : '';
        const estiloTexto = esAnulado ? 'text-decoration:line-through;color:#999;' : '';
        const numDoc      = v.numeroDoc || ((v.serie||'001') + '-' + String(v.correlativo||'').padStart(6,'0'));

        // Construcción de info de pasajeros CON fecha de nacimiento sincronizada
        let paxHTML = '';
        if (v.pasajeros && v.pasajeros.length > 0) {
          paxHTML = v.pasajeros.map(function(p) {
            var nacStr = String(p.nac || '').trim();
            var nacLabel = '';
            if (nacStr && nacStr !== '---') {
              // Convertir yyyy-mm-dd → dd/mm/yyyy para mostrar
              if (/^\d{4}-\d{2}-\d{2}$/.test(nacStr)) {
                var pts = nacStr.split('-');
                nacStr = pts[2] + '/' + pts[1] + '/' + pts[0];
              }
              nacLabel = ' <span style="color:#94a3b8;font-size:10px;">(Nac: ' + nacStr + ')</span>';
            }
            return '<div style="font-size:12px;">' + (p.nom||'') + nacLabel + '</div>';
          }).join('');
        } else {
          paxHTML = '<span style="color:#94a3b8;">-</span>';
        }

        let columnaBotones = '';
        if (esAnulado) {
          columnaBotones =
            '<div style="text-align:center;">' +
              '<div style="color:#dc2626;font-weight:800;font-size:16px;text-transform:uppercase;">❌ ANULADO</div>' +
              '<div style="color:#999;font-size:11px;">' + (v.fechaAnulacion ? new Date(v.fechaAnulacion).toLocaleDateString('es-PE') : '') + '</div>' +
            '</div>';
        } else {
          const safeNd = (v.numeroDoc||'').replace(/'/g,"\\'");
          const safeTi = (v.titular||'').replace(/'/g,"\\'");
          columnaBotones =
            '<div style="display:flex;flex-direction:column;gap:3px;min-width:76px;">' +
            '<button onclick="verBoletoCompleto(\'' + safeNd + '\')" style="background:var(--acento);color:white;border:none;padding:5px 6px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;width:100%;">👁 Ver</button>' +
            '<button onclick="reimprimirBoleto(\'' + safeNd + '\')" style="background:var(--exito);color:white;border:none;padding:5px 6px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;width:100%;">🖨 Reimpr.</button>' +
            '<button class="btn-anular" onclick="anularDocumento(\'' + safeNd + '\',\'' + (v.correlativo||'') + '\',\'' + safeTi + '\',\'' + (v.total||0) + '\')" style="width:100%;font-size:11px;padding:5px 6px;">✕ Anular</button>' +
            '</div>';
        }

        return '<tr style="' + estiloFila + '">' +
          '<td style="padding:15px;border-bottom:1px solid var(--borde);' + estiloTexto + '">' + (v.fecha||'') + '</td>' +
          '<td style="padding:15px;border-bottom:1px solid var(--borde);' + estiloTexto + '"><strong>' + numDoc + '</strong></td>' +
          '<td style="padding:15px;border-bottom:1px solid var(--borde);' + estiloTexto + '"><b>' + (v.titular||'') + '</b></td>' +
          '<td style="padding:15px;border-bottom:1px solid var(--borde);' + estiloTexto + '">' + (v.ruta||'') + '</td>' +
          '<td style="padding:12px 15px;border-bottom:1px solid var(--borde);' + estiloTexto + '">' + paxHTML + '</td>' +
          '<td style="padding:15px;border-bottom:1px solid var(--borde);' + estiloTexto + '"><strong>$ ' + (v.total||'0.00') + '</strong></td>' +
          '<td style="padding:15px;border-bottom:1px solid var(--borde);' + estiloTexto + '">' + (v.staff||'') + '</td>' +
          '<td style="padding:15px;border-bottom:1px solid var(--borde);">' + columnaBotones + '</td>' +
          '</tr>';
      }).join('');
    }

