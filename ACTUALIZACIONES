      }

      document.getElementById('lista-alertas').innerHTML = alertasActivas.map(function(a) {
        // Restaurar colores originales: rojo claro para tarjeta, rojo oscuro para badge
        const colorFondo = '#fee2e2'; // Rojo claro
        const colorBadge = '#dc2626'; // Rojo oscuro
        
        const df = parseInt(a.diasFaltan || 0);
        let etiqueta = df === 0 ? 'HOY' : df === 1 ? 'MAÑANA' : df === 2 ? 'EN 2 DÍAS' : 'AYER';

        return '<tr style="background:' + colorFondo + ';">' +
          '<td style="padding:15px;"><div style="font-weight:700;">' + (a.pasajero||a.titular||'') + '</div><div style="font-size:11px;">Titular: ' + (a.titular||'') + '</div></td>' +
          '<td style="padding:15px;">' + (a.ruta||'') + '</td>' +
          '<td style="padding:15px;">' +
            '<div style="display:inline-block;background:' + colorBadge + ';color:white;padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;">' + etiqueta + '</div>' +
            '<div style="font-size:13px;font-weight:600;margin-top:4px;color:' + colorBadge + ';">' + (a.tipo||'') + '</div>' +
            '<div style="font-size:12px;color:#64748b;">' + (a.salida||a.fecha||'') + '</div>' +
          '</td>' +
          '<td style="padding:15px;text-align:center;">' +
            '<div style="display:flex;flex-direction:column;gap:6px;align-items:center;">' +
            '<a href="https://wa.me/51' + (a.cel||'') + '?text=Hola%20' + encodeURIComponent(a.titular||'') + '" target="_blank" style="background:#10b981;color:white;padding:8px 14px;border-radius:8px;text-decoration:none;font-weight:700;display:inline-block;font-size:12px;">WhatsApp</a>' +
            '<button onclick="descartarAlerta(\'' + (a.key).replace(/'/g,"\\'") + '\')" style="background:#22c55e;color:white;border:none;padding:7px 14px;border-radius:8px;cursor:pointer;font-weight:700;font-size:11px;">✅ Marcar OK</button>' +
            '</div>' +
