        if(status) { status.innerHTML = '&#9679; Sincronizado'; status.style.color = '#10b981'; }
      } catch(e) {
        if(status) { status.innerHTML = '&#9679; Error Sync'; status.style.color = '#ef4444'; }
      }
    }

