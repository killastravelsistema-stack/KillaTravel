      if (id === 'boletos') cargarBoletos();
      if (id === 'check')   cargarAlertas();
      if (id === 'pax')     cargarPasajeros();
      if (id === 'datos')   cargarDatos();
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

