        if (pasajeros.length === 0) { grid.innerHTML = '<p style="color:var(--texto-gris);">No hay pasajeros registrados</p>'; return; }
        
        // Función inyectada en string para el onClick
        window._clickPax = function(nombre) {
          document.getElementById('buscMaestro').value = nombre;
          abrirDatos(document.querySelector('[onclick="abrirDatos(this)"]'));
          buscar();
        };

        grid.innerHTML = pasajeros.map(function(p) {
          const inicial = p.titular ? p.titular[0] : 'P';
          return '<div onclick="_clickPax(\'' + (p.titular||'').replace(/'/g,"\\'") + '\')" style="background:white;padding:20px;border-radius:16px;border:1px solid var(--borde);display:flex;align-items:center;gap:15px;cursor:pointer;transition:transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform=\'scale(1.02)\'; this.style.boxShadow=\'0 4px 12px rgba(0,0,0,0.08)\'" onmouseout="this.style.transform=\'scale(1)\'; this.style.boxShadow=\'none\'">' +
            '<div style="width:50px;height:50px;background:var(--primario);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;">' + inicial + '</div>' +
            '<div><b style="color:var(--primario);">' + (p.titular||'') + '</b><br><small style="color:var(--texto-gris);">TEL: ' + (p.doc||'') + '</small></div>' +
            '</div>';
        }).join('');
      } catch(err) {
        document.getElementById('pax-grid').innerHTML = '<p style="color:#ef4444;">❌ Error al cargar pasajeros</p>';
      }
    }

    // ═══════════════════════════════════════════
    //  BUSCAR
    // ═══════════════════════════════════════════
    async function buscar() {
      const q = document.getElementById('buscMaestro').value.trim();
      if (!q) {
        // Sin query: recargar sección activa
        var secActiva = '';
        document.querySelectorAll('.seccion').forEach(function(s) { if (s.classList.contains('activa')) secActiva = s.id; });
        if (secActiva === 'boletos') { cargarBoletos(); return; }
        if (secActiva === 'datos')   { cargarDatos(); return; }
        if (secActiva === 'pax')     { cargarPasajeros(); return; }
        if (secActiva === 'check')   { cargarAlertas(); return; }
        cargarDashboard(); return;
      }
      // Detectar sección activa
      var seccionActiva = 'dash';
      document.querySelectorAll('.seccion').forEach(function(s) { if (s.classList.contains('activa')) seccionActiva = s.id; });

      try {
        var QU = q.toUpperCase().trim();

        if (seccionActiva === 'datos') {
          // Filtrar directamente en caché de datos (o recargar)
          var rows = window._datosRowsCache || [];
          if (!rows.length) { await cargarDatos(); rows = window._datosRowsCache || []; }
          var filtrados = rows.filter(function(r) {
            var fLarga = '';
            var rObj = _parseFecha(r.fecha);
            if(rObj) {
               var mesArr = ['ENERO','FEBRERO','MARZO','ABRIL','MAYO','JUNIO','JULIO','AGOSTO','SEPTIEMBRE','OCTUBRE','NOVIEMBRE','DICIEMBRE'];
               fLarga = rObj.getDate() + ' DE ' + mesArr[rObj.getMonth()];
            }
            var hay = [r.titular,r.pasajero,r.dni_ruc,r.celular,r.ruta,r.aerolinea,r.codigo_reserva,r.numero_doc,r.counter,r.tipo_emision,r.fecha, fLarga]
              .join(' ').toUpperCase();
            return hay.indexOf(QU) !== -1;
          });
          renderDatos(filtrados);
          return;
        }

        if (seccionActiva === 'boletos') {
          db = await _fetchVentas(q);
          renderBoletos(db);
          return;
        }

        if (seccionActiva === 'pax') {
          db = await _fetchVentas(q);
          cargarPasajeros();
          return;
        }

        if (seccionActiva === 'check') {
          db = await _fetchVentas(q);
          cargarAlertas();
          return;
        }

        // Por defecto: Balance
        db = await _fetchVentas(q);
        renderDashboard();
        document.querySelectorAll('.menu-item').forEach(function(m) { m.classList.remove('activo'); });
        var dashMenu = document.querySelector('[onclick="ir(\'dash\', this)"]');
        if (dashMenu) dashMenu.classList.add('activo');
        document.querySelectorAll('.seccion').forEach(function(s) { s.classList.remove('activa'); });
        document.getElementById('dash').classList.add('activa');
      } catch(err) {
        alert('❌ Error al buscar: ' + (err.message||''));
      }
    }

    // ═══════════════════════════════════════════
    //  GENERAR TICKET (100% IDÉNTICO AL ORIGINAL)
    // ═══════════════════════════════════════════
    function generarTicket(v) {
      let filas = '';
      (v.pasajeros || []).forEach(function(p) {

        // ── Fecha de nacimiento: soporte múltiple formatos (robusto y permanente) ──
        var nacimiento = '---';
        var nacStr = String(p.nac || '').trim();
        if (nacStr && nacStr !== '---' && nacStr !== '') {
          // yyyy-mm-dd (del input type="date")
          if (/^\d{4}-\d{2}-\d{2}$/.test(nacStr)) {
            var pts = nacStr.split('-');
            nacimiento = pts[2] + '/' + pts[1] + '/' + pts[0].slice(-2);
          }
          // dd/mm/yyyy (ya formateado)
          else if (/^\d{1,2}\/\d{1,2}\/\d{4}$/.test(nacStr)) {
            var pts = nacStr.split('/');
            nacimiento = pts[0].padStart(2,'0') + '/' + pts[1].padStart(2,'0') + '/' + pts[2].slice(-2);
          }
          // dd/mm/yy (ya en formato corto)
          else if (/^\d{1,2}\/\d{1,2}\/\d{2}$/.test(nacStr)) {
            nacimiento = nacStr;
          }
          // dd-mm-yyyy
          else if (/^\d{1,2}-\d{1,2}-\d{4}$/.test(nacStr)) {
            var pts = nacStr.split('-');
            nacimiento = pts[0].padStart(2,'0') + '/' + pts[1].padStart(2,'0') + '/' + pts[2].slice(-2);
          }
        }

        // ── Importe: blindado contra undefined, null, vacío ──
        var precio = 0;
        var preStr = String(p.pre !== undefined && p.pre !== null ? p.pre : '0').trim();
        if (preStr !== '') {
          var parsedPre = parseFloat(preStr);
          if (!isNaN(parsedPre)) precio = parsedPre;
        }

        filas += '<tr><td>' + (p.nom||'') + '</td><td>' + nacimiento + '</td><td>$ ' + precio.toFixed(2) + '</td></tr>';
      });

