          <input type="date" class="p_ret">
        </div>
        <div class="campo">
          <label>NACIMIENTO</label>
          <input type="date" class="p_nac" required>
        </div>
        <div class="campo">
          <label>PRECIO</label>
          <div style="display:flex; border:2px solid var(--borde-notorio); border-radius:8px; overflow:hidden; background:#fff; align-items:center;">
            <select class="p_moneda" style="padding:10px 8px; border:none; border-right:1px solid #e2e8f0; font-size:13px; font-weight:700; background:transparent; color:#1e293b; outline:none; cursor:pointer;">
