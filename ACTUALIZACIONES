    function calcularTotal() {
      let t = 0;
      document.querySelectorAll('.p_pre').forEach(p => t += parseFloat(p.value || 0));
      document.getElementById('i_total').value = t.toFixed(2);
      const com = parseFloat(document.getElementById('i_comision').value || 0);
      document.getElementById('i_neto').value = (t - com).toFixed(2);
    }

    // ═══════════════════════════════════════════
    //  REGISTRAR VENTA → SUPABASE
    // ═══════════════════════════════════════════
    async function registrarVenta(e) {
      e.preventDefault();
      if (_guardando) return;

      // Validaciones
      if (!document.getElementById('i_ofi').value)   { alert('⚠️ Selecciona una oficina'); return; }
      if (!document.getElementById('i_tipo').value)  { alert('⚠️ Selecciona un servicio'); return; }
      if (!document.getElementById('i_staff').value) { alert('⚠️ Selecciona un counter'); return; }
      if (!document.getElementById('i_meto').value)  { alert('⚠️ Selecciona una forma de pago'); return; }

      const paxs = [];
      let paxError = '';
      document.querySelectorAll('.pax-row').forEach(function(r, idx) {
        var nom = r.querySelector('.p_nom').value.trim();
        var sal = r.querySelector('.p_sal').value;
        var pre = r.querySelector('.p_pre').value;
        if (!nom)  paxError = 'El pasajero ' + (idx+1) + ' no tiene nombre.';
        if (!sal)  paxError = paxError || 'El pasajero ' + (idx+1) + ' no tiene fecha de salida.';
        if (!pre)  paxError = paxError || 'El pasajero ' + (idx+1) + ' no tiene precio.';
        paxs.push({
          nom: nom.toUpperCase(),
          sal: sal,
          ret: r.querySelector('.p_ret').value || '---',
          nac: r.querySelector('.p_nac').value,
          pre: pre
        });
      });
      if (paxs.length === 0) { alert('⚠️ Agrega al menos un pasajero'); return; }
      if (paxError)          { alert('⚠️ ' + paxError); return; }

      const v = {
        fecha:          new Date().toLocaleDateString('es-PE'),
        titular:        document.getElementById('i_titular').value.toUpperCase(),
        doc:            document.getElementById('i_doc').value,
        cel:            document.getElementById('i_cel').value,
        ofi:            document.getElementById('i_ofi').options[document.getElementById('i_ofi').selectedIndex].text,
        serie:          document.getElementById('i_ofi').value,
        ruta:           document.getElementById('i_ruta').value.toUpperCase(),
        aerolinea:      document.getElementById('i_aerolinea').value.toUpperCase(),
        codigo_reserva: document.getElementById('i_codigo_reserva').value.toUpperCase(),
        tipo:           document.getElementById('i_tipo').value,
        staff:          document.getElementById('i_staff').value,
        total:          document.getElementById('i_total').value,
        neto:           document.getElementById('i_neto').value,
        comision:       document.getElementById('i_comision').value,
        met:            document.getElementById('i_meto').value,
        pasajeros:      paxs
      };

      // UI loading
      _guardando = true;
      const btn = document.getElementById('btnGuardar');
      const textoOriginal = btn.innerHTML;
      btn.innerHTML = '<span style="display:flex;align-items:center;gap:10px;justify-content:center;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Guardando en Supabase...</span>';
      btn.disabled = true;

      try {
        // Obtener último correlativo
        const { data: maxData } = await _supa.from('ventas').select('correlativo').order('correlativo', { ascending: false }).limit(1);
        const ultimoCorr = (maxData && maxData.length > 0 && maxData[0].correlativo) ? parseInt(maxData[0].correlativo) : 0;
        const correlativo = ultimoCorr + 1;
        const serie       = v.serie || '001';
        const numeroDoc   = serie + ' - N°' + String(correlativo).padStart(6, '0');

        const filas = paxs.map(function(pax) {
          return {
            numero_doc: numeroDoc, fecha: v.fecha, titular: v.titular, dni_ruc: v.doc,
            pasajero: pax.nom, codigo_reserva: v.codigo_reserva||'', aerolinea: v.aerolinea||'',
            ruta: v.ruta, fecha_salida: pax.sal||'', fecha_retorno: _fmtDDMMYYYY(pax.ret||''),
            celular: v.cel, direccion: v.ofi, tipo_emision: v.tipo, counter: v.staff,
            metodo_pago: v.met, neto: parseFloat(v.neto||0), comision: parseFloat(v.comision||0),
            total: parseFloat(v.total||0), fecha_nacimiento: pax.nac||'',
            importe_individual: parseFloat(pax.pre||0), anulado: false,
            serie: serie, correlativo: correlativo
          };
        });

        const { error } = await _supa.from('ventas').insert(filas);
        if (error) throw error;

        v.correlativo = correlativo;
        v.numeroDoc   = numeroDoc;
        v.id          = correlativo;
        v.anulado     = false;
        db.unshift(v);
        generarTicket(v);
        e.target.reset();
        document.getElementById('pax-container').innerHTML = '';
        agregarFilaPax();
        cargarStats();
      } catch(err) {
        alert('❌ Error al guardar: ' + (err.message || String(err)));
      } finally {
        _guardando = false;
        btn.innerHTML = textoOriginal;
        btn.disabled = false;
        if (typeof lucide !== 'undefined') lucide.createIcons();
      }
    }

    // ═══════════════════════════════════════════
    //  ANULAR DOCUMENTO → SUPABASE
    // ═══════════════════════════════════════════
    async function anularDocumento(numeroDoc, correlativo, titular, total) {
      if (!confirm('⚠️ ¿ANULAR ESTE DOCUMENTO?\n\nDocumento: ' + numeroDoc + '\nTitular: ' + titular + '\nTotal: $' + total + '\n\nEsta acción NO se puede deshacer.\n\n¿Continuar?')) return;
      try {
        const { error } = await _supa.from('ventas').delete().eq('numero_doc', numeroDoc);
        if (error) throw error;
        const doc = db.find(d => d.numeroDoc === numeroDoc || String(d.correlativo) === String(correlativo));
        if (doc) { doc.anulado = true; doc.fechaAnulacion = new Date().toISOString(); }
        alert('✅ Documento ANULADO correctamente');
        cargarDashboard();
        cargarBoletos();
      } catch(err) {
        alert('❌ Error al anular: ' + (err.message || String(err)));
      }
    }

    // ═══════════════════════════════════════════
    //  CARGAR DASHBOARD
    // ═══════════════════════════════════════════
    async function cargarDashboard() {
      try {
        db = await _fetchVentas();
        renderDashboard();
        cargarStats();
      } catch(err) {
        document.getElementById('lista-global').innerHTML =
          '<tr><td colspan="6" style="padding:40px;text-align:center;color:#ef4444;">❌ Error al cargar datos: ' + (err.message||'') + '</td></tr>';
      }
    }

    function cargarStats() {
      var totalBoletos = db.filter(function(v){ return !v.anulado; }).length;
      var totalCobrado = 0, totalUtilidad = 0, alertas = 0;
      var hoy = new Date(); hoy.setHours(0,0,0,0);
      db.forEach(function(v) {
        if (v.anulado) return;
        totalCobrado += parseFloat(v.total||0)||0;
        totalUtilidad += parseFloat(v.comision||0)||0;
        var fSal = _parseFecha(v.fechaSalida);
        if (fSal) { fSal.setHours(0,0,0,0); var d = Math.floor((fSal-hoy)/86400000); if (d>=0&&d<=2) alertas++; }
      });
      document.getElementById('st-t').innerText     = totalBoletos;
      document.getElementById('st-c').innerText     = '$ ' + totalCobrado.toFixed(2);
      if (document.getElementById('st-n')) document.getElementById('st-n').innerText = '$ ' + totalUtilidad.toFixed(2);
      if (document.getElementById('st-u')) document.getElementById('st-u').innerText = '$ ' + totalUtilidad.toFixed(2);
      document.getElementById('st-alert').innerText = alertas;
    }

    function renderDashboard() {
      if (db.length === 0) {
        document.getElementById('lista-global').innerHTML =
          '<tr><td colspan="6" style="padding:40px;text-align:center;color:var(--texto-gris);">No hay registros aún</td></tr>';
        return;
      }

      document.getElementById('lista-global').innerHTML = db.map(v => {
        const esAnulado   = v.anulado;
        const estiloFila  = esAnulado ? 'opacity:0.6;background:#fef2f2;' : '';
        const estiloTexto = esAnulado ? 'text-decoration:line-through;color:#999;' : '';
        const estadoCol   = esAnulado
          ? '<span style="color:#dc2626;font-weight:800;font-size:14px;">❌ ANULADO</span>'
          : '<span style="color:var(--exito)">● Emitido</span>';
        const accionCol   = esAnulado
          ? '<span style="color:#dc2626;font-size:12px;font-weight:700;">ANULADO</span>'
          : '<button class="btn-anular" onclick="anularDocumento(\'' + (v.numeroDoc||'') + '\',\'' + (v.correlativo||'') + '\',\'' + v.titular.replace(/'/g,"\\'") + '\',\'' + v.total + '\')">Anular</button>';

        return '<tr style="' + estiloFila + '">' +
