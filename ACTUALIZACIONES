    }

    // ═══════════════════════════════════════════
    //  IMPORTAR DESDE GOOGLE SHEETS → SUPABASE
    // ═══════════════════════════════════════════
    async function importarDesdeSheet() {
      var text = document.getElementById('import-textarea').value.trim();
      if (!text) { alert('⚠️ Pega primero los datos'); return; }
      var filas = [];
      if (text.includes(' | ')) {
        text.split('\n').forEach(function(line) {
          if (!line.trim()) return;
          var p = line.split('|').map(function(x) { return x.trim(); });
          if (p.length >= 7) {
            var arr = new Array(20).fill('');
            arr[1] = p[1];
            arr[2] = p[0];
            arr[4] = p[0];
            arr[7] = p[2];
            var fdates = p[3] ? p[3].split('-') : [];
            arr[8] = fdates[0] ? fdates[0].trim() : '';
            arr[9] = fdates[1] ? fdates[1].trim() : '';
            arr[10] = p[4] ? p[4].replace('📞', '').trim() : '';
            arr[13] = p[5];
            arr[14] = p[6];
            var totStr = p[7] ? p[7].replace(/S\/\s*/, '').trim() : '0';
            arr[15] = '0';
            arr[16] = '0';
            arr[17] = totStr;
            filas.push(arr);
          }
        });
      } else {
        filas = parseTSV(text);
      }
      if (filas.length === 0) { alert('⚠️ No se encontraron filas'); return; }

      var msgEl = document.getElementById('import-progress');
      msgEl.style.color = '#7c3aed';
      msgEl.textContent = '⏳ Obteniendo correlativo máximo...';

      var { data: maxData } = await _supa.from('ventas').select('correlativo').order('correlativo', { ascending: false }).limit(1);
      var nextCorr = (maxData && maxData[0] ? parseInt(maxData[0].correlativo) : 0) + 1;

      var registros = [];
      var lastTitular = '', lastFecha = '', lastCorr = 0, lastSerie = '001', lastNumDoc = '';

      filas.forEach(function(cols) {
        if (cols.length < 7) return;
        var c = function(i) { return ((cols[i]||'').trim()).replace(/^["']|["']$/g,''); };

        var rawDoc     = c(0);
        var fecha      = c(1);
        var titular    = c(2).toUpperCase();
        var dniRuc     = c(3);
        var pasajero   = c(4).toUpperCase() || titular;
        var codRes     = c(5);
        var aerolinea  = c(6);
        var ruta       = c(7);
        var fSalida    = c(8);
        var rawRet     = c(9);
        var fRetorno   = (rawRet === '---' || rawRet === '----') ? '' : rawRet;
        var celular    = c(10);
        var direccion  = c(11);
        var tipoEmi    = c(12) || 'BOLETOS AÉREOS';
        var counter    = c(13);
        var metPago    = c(14);
        var neto       = parseFloat(c(15)) || 0;
        var comision   = parseFloat(c(16)) || 0;
        var rawCob     = c(17);
        var cobrado    = parseFloat(rawCob) || 0;
        var fechaNac   = c(18);

        if (!pasajero && !titular) return;                       // fila vacía
        if (rawCob.toUpperCase() === 'TRUE') return;             // anulado explícito

        var serie, correlativo, numeroDoc;
        var mDoc = rawDoc.match(/^(\d{3})\s*[-–]\s*N[°o]?0*(\d+)/i);
        if (mDoc) {
          serie = mDoc[1]; correlativo = parseInt(mDoc[2]); numeroDoc = rawDoc;
        } else if (!rawDoc) {
          // Sin número de doc: agrupar por titular+fecha consecutivos
          if (titular && titular === lastTitular && fecha === lastFecha && lastCorr > 0) {
            serie = lastSerie; correlativo = lastCorr; numeroDoc = lastNumDoc;
          } else {
            serie = '001'; correlativo = nextCorr++;
            numeroDoc = serie + ' - N°' + String(correlativo).padStart(6,'0');
          }
        } else {
          serie = '001'; correlativo = nextCorr++;
          numeroDoc = '001 - N°' + String(correlativo).padStart(6,'0');
        }

        lastTitular = titular; lastFecha = fecha;
        lastCorr = correlativo; lastSerie = serie; lastNumDoc = numeroDoc;

        registros.push({
          numero_doc: numeroDoc, fecha: fecha,
          titular: titular || '---', dni_ruc: dniRuc,
          pasajero: pasajero, codigo_reserva: codRes,
          aerolinea: aerolinea, ruta: ruta,
          fecha_salida: fSalida, fecha_retorno: fRetorno,
          celular: celular, direccion: direccion,
          tipo_emision: tipoEmi, counter: counter, metodo_pago: metPago,
          neto: neto, comision: comision, total: cobrado,
          fecha_nacimiento: fechaNac, importe_individual: cobrado,
          anulado: false, serie: serie, correlativo: correlativo
        });
      });

      if (registros.length === 0) { msgEl.textContent = '⚠️ No se parseó ningún registro válido'; return; }

      var insertados = 0, errores = 0, total = registros.length;
      msgEl.textContent = '⏳ Importando 0 / ' + total + '...';

      for (var i = 0; i < total; i += 50) {
        var batch = registros.slice(i, Math.min(i+50, total));
        msgEl.textContent = '⏳ Importando ' + Math.min(i+50, total) + ' / ' + total + '...';
        try {
          var res = await _supa.from('ventas').insert(batch);
          if (res.error) { console.error(res.error); errores += batch.length; }
          else insertados += batch.length;
        } catch(e) { errores += batch.length; }
      }

      if (insertados > 0) {
        msgEl.style.color = '#10b981';
        msgEl.textContent = '✅ ' + insertados + ' registros importados correctamente' + (errores > 0 ? ' (' + errores + ' con error)' : '');
        setTimeout(function() {
          document.getElementById('modalImportar').style.display = 'none';
          cargarDatos(); cargarDashboard();
        }, 2500);
      } else {
        msgEl.style.color = '#ef4444';
        msgEl.textContent = '❌ Error al importar. Revisa la consola. (' + errores + ' errores)';
      }
    }

    // ═══════════════════════════════════════════
    //  SINCRONIZAR SCROLLBAR DOBLE (Datos)
    // ═══════════════════════════════════════════
    (function() {
      function initDualScroll() {
        var top  = document.getElementById('datos-scroll-top');
        var main = document.getElementById('datos-scroll-main');
        var inner = document.getElementById('datos-scroll-top-inner');
        var tbl  = document.getElementById('datos-tabla');
        if (!top || !main || !inner || !tbl) return;
        // Fijar el ancho del inner al ancho real de la tabla
        function syncWidth() {
          inner.style.width = tbl.offsetWidth + 'px';
        }
        syncWidth();
        // Resize observer para actualizar si la tabla cambia
        if (window.ResizeObserver) {
          new ResizeObserver(syncWidth).observe(tbl);
        }
        // Sincronizar scroll
        var syncing = false;
        top.addEventListener('scroll', function() {
          if (syncing) return; syncing = true;
          main.scrollLeft = top.scrollLeft;
          syncing = false;
        });
        main.addEventListener('scroll', function() {
          if (syncing) return; syncing = true;
          top.scrollLeft = main.scrollLeft;
          syncing = false;
        });
      }
      // Intentar al cargar y también cuando se inicia la sección datos
      window.addEventListener('load', function() { setTimeout(initDualScroll, 500); });
      // Parche: re-init cada vez que se llama cargarDatos
      var _origCargarDatos = window.cargarDatos;
      if (typeof _origCargarDatos === 'function') {
        window.cargarDatos = function() {
          _origCargarDatos.apply(this, arguments);
          setTimeout(initDualScroll, 800);
        };
      }
    })();

    // DUAL SCROLL BOLETOS
    (function() {
      function initBoletosDualScroll() {
        var top = document.getElementById('boletos-scroll-top');
        var main = document.getElementById('boletos-scroll-main');
        var inner = document.getElementById('boletos-scroll-top-inner');
        var tbl = document.getElementById('boletos-tabla');
        if (!top || !main || !inner || !tbl) return;
        function syncWidth() { inner.style.width = tbl.offsetWidth + 'px'; }
        syncWidth();
        if (window.ResizeObserver) new ResizeObserver(syncWidth).observe(tbl);
        var syncing = false;
        top.addEventListener('scroll', function() { if (syncing) return; syncing = true; main.scrollLeft = top.scrollLeft; syncing = false; });
        main.addEventListener('scroll', function() { if (syncing) return; syncing = true; top.scrollLeft = main.scrollLeft; syncing = false; });
      }
      window.addEventListener('load', function() { setTimeout(initBoletosDualScroll, 700); });
      document.addEventListener('click', function(e) { var el = e.target && e.target.closest ? e.target.closest('[onclick]') : null; if (el && el.getAttribute('onclick') && el.getAttribute('onclick').indexOf('boletos') !== -1) setTimeout(initBoletosDualScroll, 800); });
    })();
    async function toggleVerificado(rowId, isChecked) {
      var rows = window._datosRowsCache || [];
      var r = rows.find(function(x) { return x.id === rowId; });
      if (!r) return;
      
      var obs = r.observacion || '';
      if (isChecked) {
        if (!obs.includes('[✓ REVISADO]')) {
          obs = obs ? (obs + ' [✓ REVISADO]') : '[✓ REVISADO]';
        }
      } else {
        obs = obs.replace(/\[✓ REVISADO\]/g, '').trim();
      }
      
      try {
        var { error } = await _supa.from('ventas').update({ observacion: obs }).eq('id', rowId);
        if (error) throw error;
        r.observacion = obs;
        var obsCol = document.getElementById('obs_text_' + rowId);
        if (obsCol) {
          obsCol.innerHTML = '<span style="color:#0369a1;">' + (obs || '<span style="color:#94a3b8;font-style:italic;">—</span>') + '</span>';
        }
      } catch (err) {
        alert('❌ Error al actualizar estado: ' + (err.message || String(err)));
        cargarDatos();
      }
    }

    // Filtrar por mes o fecha exacta en la tabla Base de Datos
    function filtrarPorMes(evt) {
      if (evt && evt.target.id === 'filtro-fecha') {
        document.getElementById('filtro-mes').value = '';
      } else if (evt && evt.target.id === 'filtro-mes') {
        document.getElementById('filtro-fecha').value = '';
      }

      var dateInput = document.getElementById('filtro-fecha').value; // YYYY-MM-DD
      var mes = parseInt(document.getElementById('filtro-mes').value) || 0;
      var rows = window._datosRowsCache || [];
      
      if (!mes && !dateInput) { renderDatos(rows); return; }
      
      var filtrados = rows.filter(function(r) {
        var f = r.fecha ? String(r.fecha).trim() : '';
        
        if (dateInput) {
           var pts = dateInput.split('-'); // [y, m, d]
           if(pts.length === 3) {
             var exact1 = pts[2] + '/' + pts[1] + '/' + pts[0];
             var exact2 = parseInt(pts[2],10) + '/' + parseInt(pts[1],10) + '/' + pts[0];
             if (f === exact1 || f === exact2 || f === dateInput) return true;
           }
        }

        if (mes) {
          var mp = f.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
          if (mp && parseInt(mp[2], 10) === mes) return true;
          var mi = f.match(/^(\d{4})-(\d{2})-\d{2}$/);
          if (mi && parseInt(mi[2], 10) === mes) return true;
        }
        
        return false;
      });
      renderDatos(filtrados);
    }
  </script>
