    // ═══════════════════════════════════════════
    //  DESCARGAR CHECK-IN
    // ═══════════════════════════════════════════
    function descargarCheckin() {
      var alertasTodas = window._alertasExportables || [];
      var alertasActivas = alertasTodas.filter(function(a) {
        return !_alertasDescartadas.includes(a.key);
      });
      
      if (alertasActivas.length === 0) {
        alert('ℹ️ No hay alertas activas para descargar.');
        return;
      }
      
      var csv = 'PASAJEROS,TITULAR,RUTA,FECHA,TIPO,CELULAR,ESTADO\n';
      alertasActivas.forEach(function(a) {
        var estado = (a.diasFaltan < 0) ? 'REALIZADO' : 'PENDIENTE';
        var fila = [
          '"' + (a.pasajero||'').replace(/"/g, '""') + '"',
          '"' + (a.titular||'').replace(/"/g, '""') + '"',
          '"' + (a.ruta||'').replace(/"/g, '""') + '"',
          '"' + (a.salida||'').replace(/"/g, '""') + '"',
          '"' + (a.tipo||'').replace(/"/g, '""') + '"',
          '"' + (a.cel||'').replace(/"/g, '""') + '"',
          '"' + estado + '"'
        ];
        csv += fila.join(',') + '\n';
      });
      
      var blob = new Blob(["\uFEFF"+csv], {type: "text/csv;charset=utf-8;"});
      var url = URL.createObjectURL(blob);
      var link = document.createElement("a");
      link.setAttribute("href", url);
      link.setAttribute("download", "Checkin_Activos_" + new Date().getTime() + ".csv");
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

